<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>gvOtimização</title>
  
  <link rel="stylesheet" href="style.css?v=3">
</head>
<body>

  <div id="particles-js"></div>

  <div class="app-container">
    <div class="header">
      <h1>gvOtimização</h1>
    </div>

    <div class="nav-tabs">
      <div class="tab-item active" id="tab-ativacao">Ativação</div>
      <div class="tab-item" id="tab-painel">Painel OTM</div>
    </div>

    <div class="main-card">
      
      <div id="sec-ativacao" class="content-section active">
        <p style="color:#999; text-align:center; margin-bottom:20px;">Insira seu código de acesso privado</p>
        <input type="text" id="input-codigo" spellcheck="false" autocomplete="off" placeholder="DIGITE O CÓDIGO">
        <button class="btn-action" id="btn-ativar">Ativar Agora</button>
        
        <div id="status-msg"></div>
      </div>

      <div id="sec-painel" class="content-section">
        
        <div class="function-row"><span>Otimização de Memória</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Boost de Desempenho</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Limpeza de Storage</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Modo Low Power Gaming</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Redução de Ping</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        
        <div class="function-row"><span>Proteção de Privacidade</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>VPN Integrada</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Firewall Avançado</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        
        <div class="function-row"><span>Desbloquear 120 FPS</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Mira Precision (Aimbot)</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        <div class="function-row"><span>Mira Estável (No Shake)</span><label class="switch"><input type="checkbox"><span class="slider"></span></label></div>
        
        <div style="margin-top: 25px;">
          <button id="btn-salvar" class="btn-action">Salvar Alterações</button>
          
          <a href="gvotimizacao-webclip.mobileconfig" download class="btn-action" 
             style="background:transparent; color:#00e5ff; border:1px solid #333; margin-top:10px; font-size:16px; text-decoration:none;">
             Baixar Perfil Configurado
          </a>
        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
  
  <script src="app.js?v=3"></script>

</body>
</html>
